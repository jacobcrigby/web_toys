# Render tuning (build-time). Copy to .env to override; defaults apply when unset.

# Target size in pixels for the long edge of each rendered page.
VITE_TARGET_LONG_EDGE_PX=1600

# Upper bound on render scale; caps canvas area for small source pages.
VITE_MAX_SCALE=2.0

# WebP/JPEG encode quality, between 0 and 1.
VITE_ENCODE_QUALITY=0.8

# Long-edge cap (px) for a single full-page image rendered at native resolution.
# Higher is sharper but uses more memory per page; raise it on desktop if wanted.
VITE_NATIVE_MAX_LONG_EDGE_PX=2600
